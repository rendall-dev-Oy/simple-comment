{
  "include": ["./src"],
  "exclude": [
    "./src/netlify-functions/**/*.ts",
    "./src/lib/*.ts",
    "./src/*.ts",
    "./cypress"
  ],
  "compilerOptions": {
    "baseUrl": ".",
    "paths": { "*": ["types/*"] },
    "target": "es6" ,
    "module": "commonjs",
    "lib": [
      "es6",
      "dom"
    ], 
    "types": ["jest"],
    "outDir": "./",
    "rootDir": "./src/",
    "moduleResolution": "node",
    "esModuleInterop": true
  }
}
